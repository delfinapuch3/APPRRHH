# La app ahora usa PostgreSQL (antes SQLite). Para desarrollo local, apuntá
# DATABASE_URL a un Postgres: una rama gratis de Neon (https://neon.tech) o un
# Postgres local. Ejemplo de connection string de Neon:
DATABASE_URL="postgresql://usuario:password@host.neon.tech/dbname?sslmode=require"
JWT_SECRET="cambiar-por-un-secreto-propio"
PORT=4000
